CAPYTALE_MATHADATA_TOKEN=
# Optional override:
# CAPYTALE_MATHADATA_URL=https://capytale2.ac-paris.fr/web/c-stat/mathadata

# Optional: figer une reconstruction sur un snapshot Payload précis.
# Sans cette variable, le pipeline prend le dossier horodaté le plus récent
# dans ../mathadata-website/private/payload-snapshots/.
# MATHADATA_SNAPSHOT=../mathadata-website/private/payload-snapshots/<timestamp>

# Optional: remplacer les entrées ou sorties locales par défaut.
# MATHADATA_CAPYTALE_CSV=public/data/capytale_fresh_<AAAAMMJJ>.csv
# MATHADATA_LOCAL=enquete_usages_2026/_local
